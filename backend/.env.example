# MailForge v4 — Firebase Auth + SQLite
# Copy to .env and fill in values

PORT=3000
DB_PATH=data/mailforge.sqlite

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Option A (recommended for production):
#   Paste the entire service account JSON as a single-line string
#   Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}

# Option B (local dev convenience):
#   Point to the downloaded service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=admin_changeme_before_production

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# ── SMTP (leave blank to use Ethereal auto test account) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MailForge <noreply@yourdomain.com>"
