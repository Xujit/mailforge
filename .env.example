# ──────────────────────────────────────────────
# MailForge v3 — Environment Configuration
# ──────────────────────────────────────────────

PORT=3000

# SMTP — leave blank to use Ethereal (auto test account)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MailForge <noreply@yourdomain.com>"

# JWT — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_mailforge_jwt_secret

# Admin key — used for /admin/* routes and the admin dashboard
ADMIN_KEY=admin_changeme_before_production

# Frontend URL — used in approval emails
APP_URL=http://localhost:5173

# CORS — allow frontend origin
CLIENT_URL=http://localhost:5173
